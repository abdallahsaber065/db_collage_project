{
    "compilerOptions": {
        "target": "ES2020",
        "module": "CommonJS",
        "allowJs": true,
        "checkJs": true,
        "noEmit": true,
        "moduleResolution": "node",
        "strict": true,
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "skipLibCheck": true,
        "noImplicitAny": false
    },
    "include": [
        "src/**/*"
    ],
    "exclude": [
        "node_modules"
    ]
}